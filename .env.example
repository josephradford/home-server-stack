# IMPORTANT: If any value contains a dollar sign ($), it must be escaped as $$
# Example: MyP@$$word123 should be written as MyP@$$$$word123
# This prevents Docker Compose from interpreting $ as a variable reference

# =============================================================================
# SERVER & INFRASTRUCTURE
# Global settings used across all services and setup scripts.
# These are not tied to a specific compose file.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# Core network identity of this machine
# -----------------------------------------------------------------------------
SERVER_IP=192.168.1.100
TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Domain & SSL
# Your registered domain and Let's Encrypt credentials.
# Used by scripts/ssl/setup-certbot-gandi.sh to obtain a wildcard certificate.
# All services are accessed via subdomain.DOMAIN (e.g., n8n.example.com)
# -----------------------------------------------------------------------------
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Gandi Personal Access Token for DNS-01 challenge
# certbot-dns-gandi uses this to create and delete TXT records on your behalf
# during certificate issuance and renewal.
#
# Required permissions (both must be enabled under the Domains category):
#   ✓ See and renew domain names
#   ✓ Manage domain name technical configurations
#
# To create the token:
#   1. Log into https://admin.gandi.net
#   2. Go to: Organisation → Security → Personal Access Tokens (PAT)
#      Direct link: https://admin.gandi.net/organizations/account/pat
#   3. Click "Create a token"
#   4. Select your organisation
#   5. Name it (e.g., "Home Server Certbot")
#   6. Set an expiry date (recommended: 1 year — add a reminder to rotate it)
#   7. Under Domains, enable BOTH permissions listed above
#   8. Copy the token immediately — it will not be shown again
GANDIV5_PERSONAL_ACCESS_TOKEN=your_gandi_personal_access_token_here


# =============================================================================
# CORE SERVICES  (docker-compose.yml)
# Primary user-facing services — automation and DNS/ad-blocking.
# =============================================================================

# -----------------------------------------------------------------------------
# AdGuard Home
# Network-wide ad blocking and DNS server.
# Access: https://adguard.DOMAIN  |  Direct: http://SERVER_IP:8888
# -----------------------------------------------------------------------------
ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=your_secure_adguard_password

# -----------------------------------------------------------------------------
# n8n
# Workflow automation platform.
# Access: https://n8n.DOMAIN
# -----------------------------------------------------------------------------
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here

# Performance and timeout settings
N8N_RUNNERS_TASK_TIMEOUT=1800
EXECUTIONS_TIMEOUT=1800
EXECUTIONS_TIMEOUT_MAX=3600


# =============================================================================
# NETWORK & SECURITY  (docker-compose.network.yml)
# Infrastructure services for reverse proxying, TLS, intrusion prevention,
# and VPN access. Fail2ban has no configurable .env variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Traefik
# Reverse proxy handling domain-based routing and TLS termination.
# Access: https://traefik.DOMAIN  (basic auth: admin / TRAEFIK_PASSWORD)
# -----------------------------------------------------------------------------
TRAEFIK_PASSWORD=your_secure_traefik_password

# -----------------------------------------------------------------------------
# WireGuard VPN
# System service (not Docker) providing secure remote access to the home network.
# Installed via: make wireguard-install
# Config stored at: /etc/wireguard/wg0.conf
# Peer configs stored at: data/wireguard/peers/
# -----------------------------------------------------------------------------
WIREGUARD_PORT=51820
WIREGUARD_SUBNET=10.13.13.0/24

# Public hostname or IP that VPN clients use to connect from outside your home network.
# If using Gandi DDNS (make ddns-setup), set this to: vpn.DOMAIN
# If you have a static public IP, set this to the IP directly.
# Get your current public IP with: curl ifconfig.me
# Requires port forwarding on your router: WIREGUARD_PORT/UDP → SERVER_IP
WIREGUARD_SERVERURL=vpn.your-domain.com

# Subdomain for dynamic DNS (managed by make ddns-setup).
# Creates a vpn.DOMAIN A record pointing at your public IP, updated every 5 minutes.
# Only needed if your ISP assigns a dynamic public IP.
WIREGUARD_DDNS_SUBDOMAIN=vpn

# CRITICAL: Split tunneling — only route home network and VPN subnet traffic through VPN.
# DO NOT use 0.0.0.0/0 unless full tunneling is explicitly required.
WIREGUARD_ALLOWEDIPS=192.168.1.0/24,10.13.13.0/24


# =============================================================================
# MONITORING  (docker-compose.monitoring.yml)
# Metrics collection, dashboards, and alerting.
# Prometheus and the exporters (node-exporter, cAdvisor) have no configurable
# .env variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Grafana
# Metrics visualisation and dashboards.
# Access: https://grafana.DOMAIN  (login: GRAFANA_USERNAME / GRAFANA_PASSWORD)
# -----------------------------------------------------------------------------
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=your_secure_grafana_password

# -----------------------------------------------------------------------------
# Alertmanager
# Alert routing and notifications from Prometheus.
# Access: https://alerts.DOMAIN  |  Direct: http://SERVER_IP:9093
# -----------------------------------------------------------------------------
WEBHOOK_URL=http://127.0.0.1:5001/
ALERT_EMAIL_FROM=alerts@homeserver.local
ALERT_EMAIL_USER=alerts@your-domain.com
ALERT_EMAIL_PASS=your_email_app_password
ALERT_EMAIL_TO=admin@your-domain.com

# =============================================================================
# DASHBOARD  (docker-compose.dashboard.yml)
# Unified homepage with service widgets, transport, weather, and traffic data.
# =============================================================================

# -----------------------------------------------------------------------------
# Homepage
# Dashboard container displaying all service status and widgets.
# Access: https://homepage.DOMAIN
# -----------------------------------------------------------------------------

# PUID: Your user ID (run `id -u` to find this)
PUID=1000

# PGID: Must match the docker group GID for container stats to work.
# Run `getent group docker | cut -d: -f3` to find this — it is typically NOT 1000.
# If Homepage shows "unknown" status for containers, this is likely the issue.
PGID=1000

# Homepage Dashboard - Allowed Hosts (Host Header Validation)
# REQUIRED: Recent Homepage versions enforce host validation — leaving this empty causes "Host validation failed" errors.
# Set to your homepage subdomain (and any other hostnames/IPs you access it from).
# Example: "homepage.example.com" or "homepage.example.com,192.168.1.100"
HOMEPAGE_ALLOWED_HOSTS=homepage.example.com

# Google Calendar iCal URL for the calendar widget.
# Get from: Google Calendar → Settings → Integrate calendar → "Secret address in iCal format"
# Use the private URL (contains /private-TOKEN/basic.ics), not the public or embed URL.
GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/your_calendar_id%40group.calendar.google.com/private-your_token/basic.ics

# -----------------------------------------------------------------------------
# Homepage API
# Custom backend providing weather, transport, traffic, and system status widgets.
# Access: https://homepage-api.DOMAIN
# -----------------------------------------------------------------------------

# BOM Weather (Australian Bureau of Meteorology)
# Suburb name used to find the nearest observation station.
# Examples: "parramatta", "sydney", "melbourne", "brisbane"
BOM_LOCATION=parramatta

# Transport NSW — real-time public transport departures
# Get your API key from: https://opendata.transport.nsw.gov.au/
TRANSPORT_NSW_API_KEY=your_api_key_here

# Stop IDs (find at https://transportnsw.info/)
TRANSPORT_STOP_1_ID=10101323
TRANSPORT_STOP_1_NAME="North Parra Platform 1"
TRANSPORT_STOP_1_ICON=mdi-train

TRANSPORT_STOP_2_ID=2093XX
TRANSPORT_STOP_2_NAME="Bus Stop - Church St"
TRANSPORT_STOP_2_ICON=mdi-bus

# Add more stops as needed (STOP_3, STOP_4, etc.)

# TomTom Traffic — real-time traffic conditions
# Get your API key from: https://developer.tomtom.com/  (free tier: 2,500 requests/day)
TOMTOM_API_KEY=your_tomtom_api_key_here

# Traffic routes — schedule format: "Mon-Fri 07:00-09:00" or "Daily 00:00-23:59"
TRAFFIC_ROUTE_1_NAME="Morning Commute"
TRAFFIC_ROUTE_1_ORIGIN="123 Your Street, North Parramatta NSW 2151"
TRAFFIC_ROUTE_1_DESTINATION="456 Work Street, Sydney NSW 2000"
TRAFFIC_ROUTE_1_SCHEDULE="Mon-Fri 07:00-09:00"

TRAFFIC_ROUTE_2_NAME="Evening Commute"
TRAFFIC_ROUTE_2_ORIGIN="456 Work Street, Sydney NSW 2000"
TRAFFIC_ROUTE_2_DESTINATION="123 Your Street, North Parramatta NSW 2151"
TRAFFIC_ROUTE_2_SCHEDULE="Mon-Fri 17:00-19:00"

# Add more routes as needed (ROUTE_3, ROUTE_4, etc.)

# =============================================================================
# HEALTH SERVICES  (docker-compose.health.yml)
# Apple Health data ingestion via Health Auto Export iOS app.
# hae-server receives POSTs from the app and exposes a read API for Bede.
# =============================================================================

# -----------------------------------------------------------------------------
# Health Auto Export Server
# Receives health data POSTs from the Health Auto Export iOS app.
# Access: https://hae.DOMAIN
# Image:  irvinlim/apple-health-ingester (pre-built, no build step required)
# Data stored as JSON files in ./data/hae-server/
#
# iPhone setup: In Health Auto Export, set destination to:
#   URL:    https://hae.DOMAIN/api/healthautoexport/v1/localfile/ingest
#   Auth:   Bearer token: HAE_WRITE_TOKEN
# -----------------------------------------------------------------------------

# Bearer token the iOS app sends when POSTing data (Authorization: Bearer <token>).
HAE_WRITE_TOKEN=your-secure-hae-write-token


# =============================================================================
# BEDE PERSONAL ASSISTANT (docker-compose.ai.yml)
# Telegram bot wrapping Claude Code CLI for personal assistant use.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# Create a bot via @BotFather and get your user ID from @userinfobot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# -----------------------------------------------------------------------------
# Obsidian Vault
# Git repo URL for the vault. Cloned on container start, pulled before each
# Claude invocation. Use HTTPS with PAT (https://<PAT>@github.com/you/vault.git)
# or SSH (git@github.com:you/vault.git — requires VAULT_SSH_KEY_PATH below).
# Leave blank to skip vault cloning.
# -----------------------------------------------------------------------------
VAULT_REPO=
# Path on the HOST to an SSH private key with read access to the vault repo.
# Leave blank if using HTTPS PAT authentication instead.
VAULT_SSH_KEY_PATH=

# Session continuity window in minutes (default: 10)
# Follow-up messages within this window resume the same Claude session.
SESSION_TIMEOUT_MINUTES=10

# Path to the scheduled tasks file, relative to the vault root.
# Create this file in Obsidian to define proactive tasks (briefings, reminders).
# Bede reloads it every 5 minutes — no server restart needed to pick up edits.
# See bede/scheduled-tasks.example.md for the required format.
BEDE_TASKS_PATH=Bede/scheduled-tasks.md

# Claude model for Bede messages and tasks
# Interactive chat uses this model; tasks can override with `model:` in their definition
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Google Workspace MCP (workspace-mcp sidecar — Gmail, Calendar, Tasks)
# Provides Bede with access to email, calendar, and tasks via MCP tools.
#
# Setup:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application type)
#   3. Add GOOGLE_OAUTH_REDIRECT_URI as an authorised redirect URI
#   4. Enable: Gmail API, Google Calendar API, Google Tasks API
#   5. After starting the stack, visit http://SERVER_IP:8765 to complete OAuth
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
# Redirect URI is https://mcp.${DOMAIN}/oauth2callback — set this exact value
# as an authorised redirect URI in Google Cloud Console (Web application type).
